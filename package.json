{
  "name": "inventory-co",
  "productName": "ZCH Footwear Shop",
  "description": "ZCH Footwear Shop inventory management system",
  "version": "1.0.0",
  "author": "Inventory.co",
  "private": true,
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "postbuild": "node scripts/copy-installer.mjs",
    "preview": "vite preview --host",
    "start": "npm run build && electron .",
    "electron": "electron .",
    "dist": "npm run build && electron-builder --win && node scripts/copy-installer.mjs",
    "copy-installer": "node scripts/copy-installer.mjs"
  },
  "dependencies": {
    "html5-qrcode": "^2.3.8",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.21.1",
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "vite": "^5.0.8",
    "vite-plugin-pwa": "^0.21.1"
  },
  "build": {
    "appId": "com.inventoryco.desktop",
    "productName": "Inventory.co",
    "copyright": "Copyright © 2026 Inventory.co",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "asar": true,
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icons/icon-512x512.png",
      "artifactName": "${productName}-Setup-${version}.${ext}",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Inventory.co"
    }
  }
}
