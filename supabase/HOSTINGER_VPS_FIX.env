# Add these lines to your Hostinger Supabase Docker .env file
# (Docker Manager → Compose → supabase → Edit → find .env or environment section)
# Then redeploy / restart the supabase-auth container.

# --- FIX SIGNUP 500 (email confirmation without SMTP) ---
ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=true

# If your compose passes these directly to the auth service, also set:
# GOTRUE_MAILER_AUTOCONFIRM=true
# GOTRUE_DISABLE_SIGNUP=false

# After saving, restart auth:
#   docker compose restart auth

# Also run supabase/fix-signup-500.sql in Supabase SQL Editor.

# --- APP .env (on your PC, for npm run create:admin) ---
# VITE_SUPABASE_URL=https://srv1778149.hstgr.cloud
# VITE_SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
